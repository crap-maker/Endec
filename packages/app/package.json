{
  "name": "@endec/app",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test": "node ../../scripts/run-vitest.mjs",
    "test:dist": "node ../../scripts/run-vitest.mjs --config vitest.dist.config.mts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@endec/access": "workspace:*",
    "@endec/ai": "workspace:*",
    "@endec/artifacts": "workspace:*",
    "@endec/budget": "workspace:*",
    "@endec/core": "workspace:*",
    "@endec/domain": "workspace:*",
    "@endec/memory": "workspace:*",
    "@endec/runtime": "workspace:*",
    "@endec/sessions": "workspace:*",
    "@endec/tasks": "workspace:*",
    "@endec/tools": "workspace:*",
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
