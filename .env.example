TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
ENDEC_ERROR_EXPOSURE_MODE=passthrough

# Single current-model selection.
# Endec resolves one runtime currentModel from these shared env values.
# The single-model foundation stores runtime menu config at
# data/config/models.json under the active ENDEC_DATA_DIR.
ENDEC_PROVIDER=openai
ENDEC_PROVIDER_MODEL=gpt-5.4

# Deprecated compatibility-only tier envs. Do not use for new deployments.
# ENDEC_PROVIDER_CHEAP=openai
# ENDEC_PROVIDER_CHEAP_MODEL=gpt5.4
# ENDEC_PROVIDER_STRONG=openai
# ENDEC_PROVIDER_STRONG_MODEL=gpt5.5

# Provider-family runtime env. Fill the family that matches the provider ids you
# select above; Compose passes these variables through as-is.

# OpenAI-compatible / Psydo-compatible
OPENAI_BASE_URL=https://api.psydo.top/v1
OPENAI_API_KEY=replace-with-openai-compatible-api-key

# Anthropic-compatible
# ENDEC_PROVIDER=anthropic
# ENDEC_PROVIDER_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=replace-with-anthropic-compatible-api-key
# ANTHROPIC_VERSION=2023-06-01

# Other builtin provider families use the same pattern.
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_API_KEY=replace-with-glm-api-key
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_API_KEY=replace-with-kimi-api-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_API_KEY=replace-with-minimax-api-key

TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_SENDER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_ACCOUNT_ID=telegram-bot
TELEGRAM_ENABLE_BACKGROUND_WORKER=true
TELEGRAM_BACKGROUND_WORKER_ID=
TELEGRAM_BACKGROUND_WORKER_INTERVAL_MS=1000
TELEGRAM_BACKGROUND_OUTBOX_INTERVAL_MS=1000
TELEGRAM_BACKGROUND_WORKER_LEASE_DURATION_MS=30000
TELEGRAM_BACKGROUND_OUTBOX_LEASE_DURATION_MS=30000
TELEGRAM_BACKGROUND_MAX_ITERATIONS=4
ENDEC_WORKSPACE_ID=workspace_local
